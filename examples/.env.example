# Copy to `.env` in this folder and fill in. The demo agents load it automatically.
# `.env` is git-ignored; never put real keys in this `.env.example` template.

# --- voxeye → retina ---
# Mint with:  cd ../retina && uv run python -m retina.create_tenant "Demo"
VOXEYE_API_KEY=sk_replace_me
# retina base URL. Defaults to http://localhost:8000 if omitted. Update to your host.
VOXEYE_ENDPOINT=http://localhost:8000

# --- model providers (used by all demo agents) ---
GOOGLE_API_KEY=AIza...      # Gemini LLM (google.LLM)
DEEPGRAM_API_KEY=...        # STT
CARTESIA_API_KEY=sk_car_... # TTS

# --- LiveKit (required for `dev`/`start`; NOT needed for `console`) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
